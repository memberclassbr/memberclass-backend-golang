# Application Configuration
PORT=8181
LOG_LEVEL=INFO
# Set to "development", "dev" or "local" to disable response caching for
# slices that opt in. Any other value (or unset) = production (cache on).
APP_ENV=development

# Database Configuration
DB_DRIVER=postgres

# Database Connection String (configure with your existing database)
DB_DSN="postgresql://root@192.168.18.2:26257/defaultdb?sslmode=disable"
DB_EPHRA_DSN="postgresql://root@192.168.18.2:26257/defaultdb?sslmode=disable"
DB_CELETUS_DSN="postgresql://root@192.168.18.2:26257/defaultdb?sslmode=disable"


# Bunny CDN Configuration (if needed)
BUNNY_API_KEY=
BUNNY_BASE_URL=https://video.bunnycdn.com/library/
BUNNY_TIMEOUT_SECONDS=30

UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

DO_SPACES_ID=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_URL=

ILOVEPDF_BASE_URL=https://api.ilovepdf.com/v1
ILOVEPDF_API_KEYS=

INTERNAL_AI_API_KEY=

# The backend's own listening host+port. Used by legacy code paths that
# reference the BACKEND URL (e.g., magic-link endpoints served out of this
# service). Do NOT use this for customer-facing links — that's what
# PUBLIC_DOMAIN_URL is for.
PUBLIC_ROOT_DOMAIN=localhost:8181

# Customer-facing frontend root domain. Used to build:
#   - The `From` address of transactional email (naoresponder@<PUBLIC_DOMAIN_URL>)
#   - The magic-link URL root for tenants with only a subdomain
#     (e.g., tenant "demo" + root "memberclass.com.br" → demo.memberclass.com.br)
# Tenants with `customDomain` set bypass this and use their own domain.
# Must be a bare host — no scheme, no port, no path.
PUBLIC_DOMAIN_URL=memberclass.com.br

# CDN / storage prefix where tenant logos and other relative assets live.
# Used to resolve a relative `logo` column into a full URL inside email
# templates. Example: https://storage.filesmemberclass.com
# Falls back to NEXT_PUBLIC_FILES_URL for shared-.env ergonomics.
PUBLIC_FILES_URL=

TRANSCRIPTION_API_URL=http://localhost:3000

# NextAuth shared secret. Used by BearerMiddleware to verify the short-lived
# HS256 JWTs minted by the frontend at /api/auth/go-token. MUST match the
# frontend's NEXTAUTH_SECRET byte-for-byte; requests with a bad signature
# (or an empty secret here) are rejected with 401.
NEXTAUTH_SECRET=

# Resend API key for transactional email (member_import slice).
# Optional custom base URL; default is https://api.resend.com.
RESEND_API_KEY=
RESEND_BASE_URL=